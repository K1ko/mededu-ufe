{
  "name": "mededu-ufe",
  "version": "0.0.1",
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/mededu-ufe/mededu-ufe.esm.js",
  "exports": {
    ".": {
      "import": "./dist/mededu-ufe/mededu-ufe.esm.js",
      "require": "./dist/mededu-ufe/mededu-ufe.cjs.js"
    },
    "./my-component": {
      "import": "./dist/components/my-component.js",
      "types": "./dist/components/my-component.d.ts"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "convert-openapi": "js-yaml ./api/mededu.openapi.yaml > .openapi.json",
    "mock-api": "open-api-mocker --schema .openapi.json --port 5001",
    "start:app": "stencil build --dev --watch --serve",
    "start:mock": "run-s convert-openapi mock-api",
    "start": "run-p -r start:mock start:app",
    "test": "stencil-test --prod",
    "test:watch": "stencil-test --prod --watch",
    "generate": "stencil generate",
    "openapi": "openapi-generator-cli generate"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.32.0",
    "@stencil/core": "^4.27.1 || ^5.0.0-0",
    "@stencil/vitest": "^1.8.3",
    "@types/node": "^22.13.5",
    "@vitest/browser-playwright": "^4.0.0",
    "js-yaml": "^4.1.1",
    "npm-run-all": "^4.1.5",
    "open-api-mocker": "^2.0.0",
    "playwright": "^1.52.0",
    "vitest": "^4.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@material/web": "^2.4.1"
  }
}
